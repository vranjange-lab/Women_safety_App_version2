rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 1. Default Deny Catch-All
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
       return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // 2. User Profiles & Sub-collections
    match /users/{userId} {
      allow read, create, update, delete: if isOwner(userId);

      // Emergency Contacts Sub-collection
      match /contacts/{contactId} {
        allow read, create, update, delete: if isOwner(userId) && isValidId(contactId);
      }

      // Emergency History Sub-collection
      match /history/{alertId} {
        allow read, create, update, delete: if isOwner(userId) && isValidId(alertId);
      }

      // AI Safety Chat History Sub-collection
      match /chat/{messageId} {
        allow read, create, update, delete: if isOwner(userId) && isValidId(messageId);
      }

      // Journey Check-Ins Sub-collection
      match /checkins/{checkinId} {
        allow read, create, update, delete: if isOwner(userId) && isValidId(checkinId);
      }

      // Evidence Vault Sub-collection
      match /evidence/{evidenceId} {
        allow read, create, update, delete: if isOwner(userId) && isValidId(evidenceId);
      }
    }
  }
}
